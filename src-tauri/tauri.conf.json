{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LumiPDF",
  "version": "0.1.0",
  "identifier": "com.iamsuraj.lumipdf",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "LumiPDF — Beautiful Markdown Exporter",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi"],
    "publisher": "CN=2E3CE137-B314-40E9-B75A-BDF14BC67411",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
